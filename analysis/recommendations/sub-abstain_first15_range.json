{
  "hypothesis": "abstain_first15_range",
  "thesis": "SUBTRACTIVE: abstain from vwap_continuation entries when the first-15-min RTH range (09:30..09:45, 3 bars) is in the TOP TERCILE of a CAUSAL expanding-window distribution of prior days' first-15 ranges (a too-volatile / chaotic open). Mimics the proven subtractive survivor (skip worst-regime) using INTRADAY chaos instead of VIX regime. Signal stream FROZEN to the survivor; gate is a PARTITION.",
  "run_date": "2026-06-20",
  "window": "2025-01-02..2026-05-15",
  "trading_days": 342,
  "detector": "BYTE-FOR-BYTE j_daily_pattern_ratify.detect_j_vwap_continuation (imported from _edgehunt_vwap_continuation); live port = backtest/lib/watchers/vwap_continuation_watcher.py",
  "fills_authority": "real OPRA via lib.simulator_real.simulate_trade_real (C1)",
  "oos_split": "IS=2025 / OOS=2026 (calendar-year)",
  "survivor_structure": {
    "strike_offset_primary": -2,
    "strike_tier_primary": "ITM-2",
    "premium_stop_pct": -0.08,
    "exits": "v15 default",
    "qty": 3
  },
  "first15_definition": "max(high)-min(low) over the first 3 RTH 5-min bars (09:30,09:35,09:40 = 09:30..09:45 window); known by 09:45 -> strictly BEFORE every signal entry (entries >= bar TREND_BARS, morning cutoff 10:30) => causal",
  "abstention_rule": "abstain iff day's first-15 range > 66.67th percentile of PRIOR DAYS' first-15 ranges (expanding window, warmup=20 days, never abstain during warmup); PRIMARY axis = open-normalized bp",
  "lookahead_guard": "tercile cut is CAUSAL (prior-days-only expanding percentile); a full-sample tercile would be look-ahead and is reported ONLY to quantify the look-ahead premium (NOT allowed to clear the bar) (L14/L34/L57)",
  "n_signals_ungated": 158,
  "signal_fire_day_pct": 46.2,
  "signal_side_count": {
    "C": 86,
    "P": 72
  },
