# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# === Added 2026-06-14 (Stage 0: reversibility & secret hygiene) ===
# Secrets — live auth stays on disk but is NEVER tracked (use .mcp.json.example as template)
.mcp.json
**/.mcp.json
**/*.key
*.pem

# Dependency / build trees
**/node_modules/
**/.next/
backtest/.venv/

# Large data + 24/7 hoards (kept on disk, excluded from git)
crypto/data/
backtest/data/
analysis/_wf_tmp/
**/*.npz
**/*.npy
**/*.mat

# Corrupted mangled-path artifacts (literal Windows paths written on a Linux mount)
C:Users*

# Scratch
**/*.tmp
**/*.tmp.*

# Local pre-change backups (not for git; restore source if needed)
_local_backups_*/

# === Added 2026-06-20: fleet secrets + mcp backup hygiene ===
# Champion/challenger fleet per-account API secrets — NEVER tracked
automation/state/fleet/secrets.json
**/fleet-secrets.json
# Fleet runtime decision logs (ephemeral)
automation/state/fleet/decisions/
# Backup copies of mcp config carry plaintext secrets — never track them
.mcp.json.bak*
**/*.bak-winfix-*
**/*.bak
