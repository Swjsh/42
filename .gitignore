# === Added 2026-06-14 (Stage 0: reversibility & secret hygiene) ===
# Secrets — live auth stays on disk but is NEVER tracked (use .mcp.json.example as template)
.mcp.json
**/.mcp.json
**/*.key
*.pem

# Dependency / build trees
**/node_modules/
**/.next/
backtest/.venv/

# Large data + 24/7 hoards (kept on disk, excluded from git)
crypto/data/
backtest/data/
analysis/_wf_tmp/
**/*.npz
**/*.npy
**/*.mat

# Corrupted mangled-path artifacts (literal Windows paths written on a Linux mount)
C:Users*

# Scratch
**/*.tmp
**/*.tmp.*

# Local pre-change backups (not for git; restore source if needed)
_local_backups_*/

# === Added 2026-06-20: fleet secrets + mcp backup hygiene ===
# Champion/challenger fleet per-account API secrets — NEVER tracked
automation/state/fleet/secrets.json
**/fleet-secrets.json
# Fleet runtime decision logs (ephemeral)
automation/state/fleet/decisions/
# Backup copies of mcp config carry plaintext secrets — never track them
.mcp.json.bak*
**/*.bak-winfix-*
**/*.bak

# === Added 2026-06-21: companion Web Push secrets + ephemeral push state ===
# VAPID private key + push subscriptions carry the wrist-approval signing material.
# (.approve-hmac.key already matches **/*.key above; .json files do NOT — pin them.)
automation/state/.vapid.json
**/.vapid.json
automation/state/push-subscriptions.json
**/push-subscriptions.json
# Ephemeral runtime push state — single-use token ledger + rising-edge dedupe
automation/state/.approve-consumed.json
**/.approve-consumed.json
automation/state/.push-seen.json
**/.push-seen.json
# Ephemeral companion live-transcript + card-ack snooze state (per-machine runtime)
automation/state/companion-ask-feed/
**/companion-ask-feed/
automation/state/companion-card-acks.json
**/companion-card-acks.json
# Machine-specific companion config: persisted page-auth token + tailnet host.
# .companion-token is the stable x-gamma-token; .tailnet-host is this PC's
# Tailscale MagicDNS name. Both are per-machine — never tracked.
automation/state/.companion-token
**/.companion-token
automation/state/.tailnet-host
**/.tailnet-host

# pixel-office local-only assets (LimeZu: not redistributable; sources: scratch)
cockpit/assets/pixel/limezu/
cockpit/assets/pixel/sources/

cockpit/_devshot.png
