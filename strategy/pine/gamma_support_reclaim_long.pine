//@version=6
// =============================================================================
// Gamma — Support-Reclaim Long (VIX>=18)   [research candidate, 2026-06-20]
// =============================================================================
// Marks the single robust positive-expectancy signal mined from the 4,865-signal
// native MES/MNQ futures fleet (analysis/winning-signals-mine-2026-06-20.md):
//
//   LEVEL_REJECT_LIVE | long  — a VOLUME-CONFIRMED SUPPORT RECLAIM:
//     1. A reversal bar's LOW pokes a named support (within tolerance, from above),
//     2. prints a HIGHER-LOW vs the prior bar and closes GREEN,
//     3. on volume >= volMult x the trailing 20-bar average,
//     4. and price reclaims that bar's BODY MIDPOINT within 6 bars.
//   Regime gate: only when VIX >= vixMin (default 18). Below 18 the edge is a
//   coin-flip (MES -$6/c, MNQ -$11/c); at 18-22 it is +$60/+$98/c at 75-87% WR,
//   and >22 even better — stable across 2025 (IS) AND 2026 (OOS), both instruments.
//
// Faithful to backtest/lib/watchers/shotgun_scalper_detector.py::_detect_level_reject
// (bullish path). RESEARCH/WATCH-ONLY — not a production order signal (Rule 9 /
// OP-16: bull-side reclaim stays DRAFT until J ratifies). $0, paper.
// =============================================================================
indicator("Gamma Support-Reclaim Long (VIX>=18)", overlay=true, max_lines_count=200, max_labels_count=200)

// ---- inputs ----------------------------------------------------------------
grpSig   = "Signal"
volMult  = input.float(1.5,  "Volume vs 20-bar avg (x)", minval=1.0, step=0.1, group=grpSig)
volLen   = input.int(20,     "Volume average length",     minval=5,  group=grpSig)
midWindow= input.int(6,      "Midpoint-reclaim window (bars)", minval=1, maxval=12, group=grpSig)
tolPct   = input.float(0.05, "Support touch tolerance (% above)", step=0.01, group=grpSig) / 100.0
buffPct  = input.float(0.02, "Stop buffer below reversal low (%)", step=0.01, group=grpSig) / 100.0

grpReg   = "Regime gate"
useVix   = input.bool(true,  "Require VIX >= threshold", group=grpReg)
vixSym   = input.symbol("TVC:VIX", "VIX symbol", group=grpReg)
vixMin   = input.float(18.0, "VIX minimum", step=0.5, group=grpReg)

grpLvl   = "Support sources"
usePivot = input.bool(true,  "Pivot lows", group=grpLvl)
pivL     = input.int(3, "Pivot left",  minval=1, group=grpLvl)
pivR     = input.int(3, "Pivot right", minval=1, group=grpLvl)
usePDL   = input.bool(true,  "Prior-day low", group=grpLvl)
useSess  = input.bool(true,  "Session low",   group=grpLvl)

// ---- data ------------------------------------------------------------------
vix = request.security(vixSym, timeframe.period, close, ignore_invalid_symbol=true)
vixOk = not useVix or (not na(vix) and vix >= vixMin)
volAvg = ta.sma(volume, volLen)

// prior-day low (yesterday's RTH/day low)
pdl = request.security(syminfo.tickerid, "D", low[1], lookahead=barmerge.lookahead_off)

// session low (running min since session start)
var float sessLow = na
newSession = ta.change(time("D")) != 0
sessLow := newSession ? low : na(sessLow) ? low : math.min(sessLow, low)

// rolling pivot-low memory (last few swing lows)
pl = ta.pivotlow(low, pivL, pivR)
var array<float> supports = array.new<float>()
if usePivot and not na(pl)
    array.push(supports, pl)
    if array.size(supports) > 8
        array.shift(supports)

// is `lowVal` a touch of ANY active support (poke from above, within tolerance)?
isTouch(float lowVal, float px) =>
    bool hit = false
    tolAbove = px * tolPct
    tolBelow = px * tolPct * 4.0
    // pivot lows
    if usePivot and array.size(supports) > 0
        for i = 0 to array.size(supports) - 1
            s = array.get(supports, i)
            if lowVal <= s + tolAbove and lowVal >= s - tolBelow
                hit := true
    if usePDL and not na(pdl)
        if lowVal <= pdl + (pdl*tolPct) and lowVal >= pdl - (pdl*tolPct*4.0)
            hit := true
    if useSess and not na(sessLow)
        if lowVal <= sessLow + (sessLow*tolPct) and lowVal >= sessLow - (sessLow*tolPct*4.0)
            hit := true
    hit

// ---- reversal-bar detection (the "rej" candle) -----------------------------
// touch support + higher-low vs prior + green close + volume confirmation
isRevBar = isTouch(low, close) and (low > low[1]) and (close > open) and (volume >= volMult * volAvg)
revMidNow = (open + close) / 2.0

// arm on a reversal bar; valid for `midWindow` bars; one-shot trigger on midpoint reclaim
var float armMid  = na
var float armLow  = na
var int   armAge  = na

if isRevBar
    armMid  := revMidNow
    armLow  := low
    armAge  := 0
else if not na(armAge)
    armAge := armAge + 1
    if armAge > midWindow
        armMid := na
        armLow := na
        armAge := na

armed = not na(armMid)
longSignal = armed and (close > armMid) and vixOk

// one-shot: disarm after firing
var bool justFired = false
justFired := false
if longSignal
    justFired := true
    armMid := na
    armLow := na
    armAge := na

// ---- plot ------------------------------------------------------------------
plotshape(justFired, title="Support-Reclaim Long", style=shape.triangleup,
          location=location.belowbar, color=color.new(color.lime, 0), size=size.small,
          text="RECLAIM")

// draw stop on the firing bar (just below the recent reversal low)
if justFired
    stopPxFinal = math.min(low, low[1]) * (1.0 - buffPct)
    line.new(bar_index, stopPxFinal, bar_index + 8, stopPxFinal, color=color.red,
             width=1, style=line.style_dashed)
    label.new(bar_index, high, text="LONG  VIX " + str.tostring(vix, "#.0"),
              style=label.style_label_down, color=color.new(color.green, 20),
              textcolor=color.white, size=size.small)

// regime shading: subtle background when VIX gate is satisfied
bgcolor(vixOk ? color.new(color.green, 94) : na, title="VIX>=min regime")

// alert
alertcondition(justFired, title="Gamma Support-Reclaim Long",
     message="Gamma: support-reclaim LONG fired (VIX>=18 gate). {{ticker}} {{interval}} @ {{close}}")
